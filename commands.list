# 常用命令 - 快速参考

# 1. 设置数据库路径（每次新终端必须先执行）
export SQLITE_DB_PATH=/home/richard/shared/jianglei/payroll/payroll_database.db

# 2. 端到端刷新（推荐入口：batch_process.py + 全部 9 步清洗）
./sqlite_payroll_details_refresh.sh                                          # 交互模式（9 个 cleansing 步骤会逐个 prompt "请输入 yes"）
yes yes | ./sqlite_payroll_details_refresh.sh                                # 自动模式：必须用 `yes yes`（不是 `yes`），CI/cron 友好
# 注：GNU `yes` 不带参数时输出 'y\n'（不是 'yes\n'）—— `input()` 会拿到 'y'，导致 `confirm.strip().lower() == "yes"` 不匹配，脚本打印"已取消"并退出。
#   必须显式 `yes yes` 才会输出 'yes\n'。每个 cleansing_*.py 恰好 1 个 input() 提示（共 9 个：step0,1,3,4,5,6,7,8,9），
#   pipe 喂无限 "yes\n" 给所有子进程，无需担心被耗尽。

# 3. 仅批量处理所有 Excel 文件
python batch_process.py

# 4. 单文件处理（不清理数据库）
python batch_process.py 201406.xls

# 5. 验证日期列数据质量
python validate_date_column.py --export-html

# 6. 手动检查 Excel 数据问题（交互式，用 LibreOffice 打开 #VALUE!/#REF! 所在文件）
python one_time_pgms/open_excel_for_review.py

# 7. 生成 Excel #VALUE!/#REF! 错误报告（HTML 格式，输出到 screenshot/ 目录）
python one_time_pgms/take_excel_screenshot.py

# 8. 解析 Excel "汇总" 工作表到新表 payroll_summary（DB 只新增表，payroll_details 不动）
python one_time_pgms/parse_summary_sheets.py --dry-run              # 预览
python one_time_pgms/parse_summary_sheets.py                        # 真实入库（自动备份 DB）

# 9. 全量 Excel vs DB 逐行 reconcile + DB 一致性诊断（DB 零写入，PRAGMA query_only）
python one_time_pgms/reconcile_excel_vs_db.py --audit-only          # 仅跑任务 C 诊断
python one_time_pgms/reconcile_excel_vs_db.py                        # 完整 reconcile，输出 reconcile_report.html
# 两阶段：1) hash 集合差集 2) tolerance 匹配（|数值 diff| <= 0.01 视为相等）
# 状态：OK (无差异) / TOL (hash 不等但 tolerance 解决) / WARN (tolerance 未解决)
# Tolerance 不改 production pipeline（DB 14.09 与 Excel 14.08 差 0.01，用户接受）
# 边界：< 改成 <= 是因为 14.084999... → 14.09 与 14.08 差正好 0.01

# 9.1 提取 WARN 段到纯文本（reconcile_excel_vs_db.py 不自动生成）
python one_time_pgms/extract_warn_full.py                             # 默认: reconcile_report.html → /tmp/warn_full.txt
python one_time_pgms/extract_warn_full.py --section "Tolerance 匹配明细" --output /tmp/tol_full.txt  # TOL 段也可提取

# 9.2 导出 payroll_summary 全部记录到单文件 HTML（带 姓名/工序/车间 文本过滤 + 文件下拉）
python one_time_pgms/export_payroll_summary_html.py                  # 默认输出到 ./payroll_summary.html
python one_time_pgms/export_payroll_summary_html.py --output /tmp/summary.html  # 改输出路径

# 10. 关于 L19 工时/单位信息保留规则（special_logic.py）
# 当 计件数量 列出现 '1.5H'/'8H'/'24H'/'2套'/'3人8H'/'1台3H'/'1.5X'/'1天'/'1人半天' 等非数字字符串时，
# 把字符串以 " (L19字符串)" 格式追加到 工序全名 列（若 工序全名 不存在则用 工序 列），
# 例：'校正' → '校正 (1.5H)'，避免被 load_df_to_db 的 to_numeric(coerce).fillna(0.0) 强制转 0 导致信息丢失。
# 已在 special_logic.py L19 实现。下次跑 batch_process.py 自动生效。
# 验证：跑 reconcile 报告 "工时/单位信息保留 (L19) 诊断" 段会列出所有受影响行。

# 11. 修复源 Excel 文件 F 列 (定额) 的 #VALUE! 错误（一次性脚本, 2026-06-13 已完成）
python one_time_pgms/fix_f_column_value_error.py --dry-run                # 预览
python one_time_pgms/fix_f_column_value_error.py                          # 实际修复
python one_time_pgms/fix_f_column_value_error.py --files 202011.xls       # 限定文件
python one_time_pgms/fix_f_column_value_error.py --all                     # 扫描所有 .xls/.xlsx (默认只处理 KNOWN_FILES_WITH_ERRORS)
# 把 G 列 #VALUE! 行对应 F 列改为 0.8 + 黄底红字, .xls 自动转 .xlsx
# 备份: /home/richard/shared/jianglei/payroll/{new,old}_payroll_backup_20260612/
# 当前状态 (2026-06-13): 已修 1,678 个 F 单元格 (12 个 new_payroll 文件 .xls → .xlsx)
#
# **G 列 cached value 修复 (2026-06-13 加的三处坑, 必须满足)**:
#   1) wb.calculation.fullCalcOnLoad = False — 否则 LibreOffice 重算后 G 列公式 cached value 仍是 `<v></v>` 空
#   2) 显式 filter `--convert-to "xlsx:Calc Office Open XML"` — 隐式 xlsx filter 留下空 <v></v>
#   3) --outdir 与输入路径必须不同 — 否则 SfxBaseModel::impl_store failed 0x4c0c
#   4) build_work_list 兼容 .xls/.xlsx 后缀, 脚本可幂等运行 (首次改 .xls, 二次改 .xlsx)
#   5) 即使 total_modified==0 也要 recalc — 否则 202012.xlsx 这类原 .xlsx 文件 G 列 cached value 不会写入
#
# **不要轻易删以下错位置目录** (历史教训):
#   - 数据真实目录是 payroll_excel_processing/new_payroll/ 和 old_payroll/ (脚本工作目录, 不是父目录!)
#   - 父目录 /home/richard/shared/jianglei/payroll/new_payroll/ 是不存在的, 不要 cp 错位置
